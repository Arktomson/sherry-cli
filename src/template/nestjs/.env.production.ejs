# 生产环境配置（不入库，仅本地测试生产配置时使用）
# 真实部署靠 Docker/K8s/PaaS 注入，不依赖此文件
NODE_ENV=production
PORT=8080

# ----- 反向代理 -----
# 反向代理跳数（你的 Node 前面有几层会改请求的代理）
# 单层 Nginx=1；Cloudflare/CDN + Nginx=2；不知道用 IP 白名单
# 不设的代价：限流按代理 IP 分桶 = 全站共享一个桶，限流失效
TRUST_PROXY=1

# ----- 数据库 -----
<%_ if (database && orm === 'prisma') { _%>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp_prod
<%_ } else { _%>
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp_prod
<%_ } _%>

# ----- 鉴权 -----
# JWT_SECRET=your-production-secret-at-least-32-chars
