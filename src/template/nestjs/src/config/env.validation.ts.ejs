import * as Joi from 'joi';

/**
 * NODE_ENV 枚举
 */
export enum NodeEnv {
  Development = 'development',
  Production = 'production',
}

/**
 * 封装 NODE_ENV，供模块外使用（模块内推荐用 ConfigService）
 * - Joi 校验已保证值只能是 development / production
 */
export const nodeEnv: NodeEnv =
  (process.env.NODE_ENV as NodeEnv) ?? NodeEnv.Development;

/**
 * 获取当前运行环境对应的 env 文件路径
 */
export const getEnvFilePath = (): string => `.env.${nodeEnv}`;

/**
 * 环境变量校验 schema
 * - 启动时会校验 process.env，缺失或类型错误立即抛错
 * - 新增环境变量时同步更新此文件和对应的 .env 文件
 */
export const envValidationSchema = Joi.object({
  NODE_ENV: Joi.string().valid('development', 'production').required(),
  PORT: Joi.number().port().default(3000),

  // 反向代理跳数（仅生产环境读取）
  // - 数字：你的应用前面有几层会改请求的代理。单层 Nginx=1；CDN+Nginx=2
  // - 字符串：IP / CIDR 列表（更稳，建议高安全场景使用），如 '10.0.0.0/8, 192.168.0.0/16'
  // - 不设：req.ip 是上一跳代理 IP，限流 / 日志 / 风控会失真
  TRUST_PROXY: Joi.alternatives()
    .try(Joi.number().integer().min(0), Joi.string())
    .default(1),

  // 按需启用的字段（取消注释即生效）
<%_ if (database && orm === 'prisma') { _%>
  DATABASE_URL: Joi.string()
    .pattern(/^postgres(ql)?:\/\//)
    .required(),
<%_ } else { _%>
  // DATABASE_URL: Joi.string().uri().required(),
<%_ } _%>
  // JWT_SECRET: Joi.string().min(32).required(),
});
