<%_ if (validation) { _%>
import { ValidationPipe } from '@nestjs/common';
<%_ } _%>
<%_ if (swagger) { _%>
import { DocumentBuilder, SwaggerModule } from '@nestjs/swagger';
<%_ } _%>
import { NestFactory } from '@nestjs/core';
import { AppModule } from './app.module';
import { AllExceptionsFilter, TransformInterceptor } from './common';
import { nodeEnv, NodeEnv } from './config';
import { Logger, PinoLogger } from 'nestjs-pino';
import helmet from 'helmet';

async function bootstrap() {
  const app = await NestFactory.create(AppModule, { bufferLogs: true });
  // 使用 PinoLogger 替换默认 Logger（自动记录请求日志 + 结构化输出）
  app.useLogger(app.get(PinoLogger));
  // 安全头：关闭 CSP 和 crossOriginEmbedderPolicy，兼容非纯 API 项目
  app.use(
    helmet({
      contentSecurityPolicy: false,
      crossOriginEmbedderPolicy: false,
    }),
  );
  // CORS：只在开发环境开启，生产环境由部署策略（Nginx/网关）处理
  if (nodeEnv === NodeEnv.Development) {
    app.enableCors();
  }
  // 全局异常过滤器
  app.useGlobalFilters(new AllExceptionsFilter());
  // 响应格式统一
  app.useGlobalInterceptors(new TransformInterceptor());
<%_ if (validation) { _%>
  app.useGlobalPipes(
    new ValidationPipe({
      whitelist: true,
      transform: true,
      transformOptions: { enableImplicitConversion: true },
    }),
  );
<%_ } _%>
<%_ if (swagger) { _%>
  const config = new DocumentBuilder()
    .setTitle('API Documentation')
    .setDescription('NestJS API description')
    .setVersion('1.0')
    .build();
  const document = SwaggerModule.createDocument(app, config<%_ if (validation) { _%>, { deepScan: true }<%_ } _%>);
  SwaggerModule.setup('api', app, document);
<%_ } _%>
  app.enableShutdownHooks();

  await app.listen(process.env.PORT ?? 3000);
}
bootstrap();