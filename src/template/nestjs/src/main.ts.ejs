<%_ if (validation) { _%>
import { ValidationPipe } from '@nestjs/common';
<%_ } _%>
<%_ if (swagger) { _%>
import { DocumentBuilder, SwaggerModule } from '@nestjs/swagger';
<%_ } _%>
import { ConfigService } from '@nestjs/config';
import { NestFactory } from '@nestjs/core';
import type { NestExpressApplication } from '@nestjs/platform-express';
import { AppModule } from './app.module';
import { GlobalExceptionFilter, ResponseEnvelopeInterceptor } from './common';
import { nodeEnv, NodeEnv } from './config';
import { Logger } from 'nestjs-pino';
import helmet from 'helmet';

async function bootstrap() {
  const app = await NestFactory.create<NestExpressApplication>(AppModule, {
    bufferLogs: true,
  });
  if (nodeEnv === NodeEnv.Production) {
    // 生产环境通常在 Nginx / 网关 / CDN 后方。trust proxy 让 Express 信任 X-Forwarded-* 头，
    // 才能拿到真实客户端 IP（限流 / 日志 / 风控的基础）。
    // 跳数由 TRUST_PROXY 环境变量控制：单层 Nginx=1，CDN+Nginx=2，未知用 IP 白名单字符串
    const trustProxy =
      app.get(ConfigService).get<number | string>('TRUST_PROXY') ?? 1;
    app.set('trust proxy', trustProxy);
  }
  // 使用 nestjs-pino 的 Logger 替换默认 Logger（自动记录请求日志 + 结构化输出）
  // 注意：用 `Logger`（singleton）而不是 `PinoLogger`（transient，会触发 InvalidClassScopeException）
  app.useLogger(app.get(Logger));
  // 安全头：关闭 CSP 和 crossOriginEmbedderPolicy，兼容非纯 API 项目
  app.use(
    helmet({
      contentSecurityPolicy: false,
      crossOriginEmbedderPolicy: false,
    }),
  );
  // CORS：只在开发环境开启，生产环境由部署策略（Nginx/网关）处理
  if (nodeEnv === NodeEnv.Development) {
    app.enableCors();
  }
  // 全局异常过滤器
  app.useGlobalFilters(new GlobalExceptionFilter());
  // 响应格式统一
  app.useGlobalInterceptors(new ResponseEnvelopeInterceptor());
<%_ if (validation) { _%>
  app.useGlobalPipes(
    new ValidationPipe({
      whitelist: true,
      transform: true,
      transformOptions: { enableImplicitConversion: true },
    }),
  );
<%_ } _%>
<%_ if (swagger) { _%>
  const config = new DocumentBuilder()
    .setTitle('API Documentation')
    .setDescription('NestJS API description')
    .setVersion('1.0')
    .build();
  const document = SwaggerModule.createDocument(app, config);
  SwaggerModule.setup('api', app, document);
<%_ } _%>
  app.enableShutdownHooks();

  await app.listen(process.env.PORT ?? 3000);
}
bootstrap();
