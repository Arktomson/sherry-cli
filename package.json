    "download-git-repo": "^3.0.2",
    "ejs": "^3.1.10",
    "figlet": "^1.8.0",
    "fs-extra": "^11.3.0",
    "inquirer": "^9.2.10",
    "ora": "^8.1.1",
    "shelljs": "^0.8.5",
    "table": "^6.9.0"
